{
  "name": "blog-system",
  "version": "1.0.0",
  "description": "Personal Blog System - Full Stack",
  "main": "server/app.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && node app.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "seed": "cd server && node seed-db.js",
    "install:all": "npm install && cd client && npm install && cd ../server && npm install"
  },
  "keywords": ["blog", "vue", "express", "sqlite"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
